# Local Vite development. The app defaults to this URL when VITE_API_BASE_URL
# is omitted, so this file is documentation only.
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_DEPLOYMENT_MODE=offline

# Vercel production values:
# VITE_API_BASE_URL=https://YOUR_CLOUD_RUN_URL
# VITE_DEPLOYMENT_MODE=online
