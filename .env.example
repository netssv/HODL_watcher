# FRED API Key: Get for free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Deployment mode: offline keeps local refresh behavior; online uses the
# shared server cache and disables manual upstream refresh from the browser.
VITE_DEPLOYMENT_MODE=offline

# Currents API Key: Get for free at https://currentsapi.services/en/register
CURRENTS_API_KEY=

# NewsAPI Key: Get for free at https://newsapi.org/register
NEWSAPI_KEY=

# GNews API Key: https://gnews.io/
GNEWS_API_KEY=

# Coinalyze API Key: Register a basic account at https://coinalyze.net/
COINALYZE_API_KEY=

# OKX API credentials: https://www.okx.com/account/my-api
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Kraken API credentials: https://www.kraken.com/u/security/api
KRAKEN_API_KEY=
KRAKEN_PRIVATE_KEY=

# Bybit API credentials: https://www.bybit.com/app/user/api-management
BYBIT_API_KEY=
BYBIT_SECRET_KEY=
BYBIT_TESTNET=false


# Onchain & ETF Data Provider: Currently mock/simulation data is used. Set value to "mock" or leave blank.
ONCHAIN_PROVIDER=mock
ETF_PROVIDER=mock
